# Use either DATABASE_URL or the individual MYSQL_* variables below.
DATABASE_URL=

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=divant
MYSQL_SSL=false

# Hostname used for link generation, include port as well
# Helpful when the server is run through a reverse proxy
HOST=

# Set this when run behind reverse proxy
NEXT_PUBLIC_WS_URL=

# Pool lifetime in hours before it expires from inactivity.
POOL_TIMEOUT_HOURS=168